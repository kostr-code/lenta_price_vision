# Common
APP_ENV=dev
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=localhost
BACKEND_PORT=8001
BACKEND_CORS_ORIGINS=*
BACKEND_MAX_UPLOAD_MB=256
BACKEND_REQUEST_TIMEOUT_SEC=600
BACKEND_HEALTH_TIMEOUT_SEC=5
DATABASE_URL=postgresql+psycopg://price_audit:price_audit@postgres:5432/price_audit
ML_URL=http://host.docker.internal:8000
AUTO_CREATE_TABLES=1

# ML
ML_HOST=localhost
ML_PORT=8000
ML_DEVICE=cpu
MODEL_PATH=/app/models/price_tag_detector.pt
ML_ENABLE_STUB=1

# Frontend
FRONTEND_PORT=5173
VITE_BACKEND_URL=http://localhost:8001

# Demo
DEMO_DATASET_PATH=/app/data/demo
