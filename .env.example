# Common
APP_ENV=dev
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=localhost
BACKEND_PORT=8001
DATABASE_URL=postgresql+psycopg://price_audit:price_audit@postgres:5432/price_audit
ML_URL=http://ml:8000
STORE_API_URL=http://mock-store-api:8002
AUTO_CREATE_TABLES=1

# ML
ML_HOST=localhost
ML_PORT=8000
ML_DEVICE=cpu
MODEL_PATH=/app/models/price_tag_detector.pt
ML_ENABLE_STUB=1

# Mock Store API
MOCK_STORE_API_HOST=localhost
MOCK_STORE_API_PORT=8002

# Demo
DEMO_DATASET_PATH=/app/data/demo